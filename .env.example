# ============================================================
# Phishing Guard V2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT:
#   - Never commit .env to Git
#   - Docker: use service names as hostnames (e.g. "postgres")
#   - Local:  use "localhost" for all hostnames
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Docker: keep "postgres" as the host (it's the compose service name)
# Local:  change "postgres" → "localhost"
DATABASE_URL=postgresql://phishing_user:phishing_pass@postgres:5432/phishing_guard

# ── App Settings ─────────────────────────────────────────────
# Set DEBUG=true to enable SQLAlchemy query logging
DEBUG=false

# ── VirusTotal API (Optional) ────────────────────────────────
# Free API key: https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/minute, 500 requests/day
# Multiple keys (comma-separated) enable round-robin rotation:
#   VIRUSTOTAL_API_KEYS=key1,key2,key3
# Leave empty to run in heuristic-only mode (no VT lookups):
VIRUSTOTAL_API_KEYS=

# ── Email IMAP ───────────────────────────────────────────────
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your real Gmail password):
# Google Account → Security → 2-Step Verification → App Passwords
# Select "Mail" → Copy the generated 16-char password
EMAIL_PASSWORD=your-app-password

# ── File Paths ───────────────────────────────────────────────
# Directory where email attachments are saved to disk
ATTACHMENT_DIR=/app/uploads

# Path to the trained ML model (joblib file)
# Generate with: python train_model.py
MODEL_PATH=/app/data/phishing_model.joblib

# ── Limits ───────────────────────────────────────────────────
# Maximum attachment size (bytes) to analyze. Files larger than
# this are skipped and flagged. Default: 52428800 = 50 MB
MAX_ATTACHMENT_BYTES=52428800

# Enable VirusTotal hash lookup for attachments (future feature)
ENABLE_VT_HASH_LOOKUP=false
